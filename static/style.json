{
	"QMainWindow" :[
		{
			"tittle":"SISTEMA DE GESTION",
			"icon":":/white_icons/iconos/hcu.png",
			"frameless": true,
			"transluscentBg": true,
			
			"navigation":[
				{
					"moveWindow": "headerContainer",
					"tittleBar": "headerContainer"
				}
			]
		}
	],
    
	"QCustomSlideMenu" :[{
		"name": "MenuContainer",
		"defaultSize": [{
			"width": 55,
			"height": "parent"
		}],
		"collapsedSize": [{
			"width": 55,
			"height": "parent"
		}],
		"expandedSize": [{
			"width": 300,
			"height": "parent"
		}],
		"toggleButton": [{
			"buttonName": "btn_menu",
			"icons": [{
				"whenMenuIsCollapsed": ":/white_icons/iconos/menu.svg",
				"whenMenuIsExpanded": ":/white_icons/iconos/chevron-left.svg"
			}]
		}],
		"menuTransitionAnimation": [{
			"animationDuration": 500,
			"animationEasingCurve": "Linear"
		}]
	}]
}
