       <property name="styleSheet">
        <string notr="true">QPushButton#btn_ingresar {
    /* Degradado lineal de azul oscuro a azul medio */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, 
        stop:0 rgba(31, 69, 110, 255), 
        stop:1 rgba(74, 144, 226, 255)); 
    
    color: white;
    border-radius: 20px;
    font-weight: bold;
    border: none;
}

/* EFECTO CUANDO PASAS EL MOUSE */
QPushButton#btn_ingresar:hover {
    /* Invertimos o aclaramos el degradado para que se note el movimiento */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, 
        stop:0 rgba(41, 89, 140, 255), 
        stop:1 rgba(100, 170, 255, 255));
}

/* EFECTO CUANDO HACES CLIC */
QPushButton#btn_ingresar:pressed {
    /* Un degradado mucho más oscuro para dar sensación de hundido */
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, 
        stop:0 rgba(20, 45, 75, 255), 
        stop:1 rgba(31, 69, 110, 255));
    padding-top: 2px;
}</string>
